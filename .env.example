# Wisdom Studio environment template.
# Copy to `.env` for local dev. The Docker image accepts these as -e flags.
#
# Most users will set these from the GUI on first run rather than here.

# --- Studio runtime --------------------------------------------------------
# Where Studio persists agents, configs, and SQLite databases.
WISDOM_STUDIO_DATA_DIR=./.wisdom-studio

# Backend port (FastAPI). Frontend dev server proxies to this.
WISDOM_STUDIO_API_PORT=8765

# Frontend dev port (Vite). Production image serves the SPA on 3000.
WISDOM_STUDIO_WEB_PORT=5173

# --- Wisdom Layer SDK ------------------------------------------------------
# Optional license key. Free tier works without one. Pro/Enterprise unlocks
# additional features — see the wisdom-layer SDK docs for details.
WISDOM_LAYER_LICENSE=

# SDK data root (where install_id and per-license agent registry live).
# Defaults to ~/.wisdom_layer when unset.
# WL_DATA_DIR=

# --- LLM provider keys -----------------------------------------------------
# Setting any one of these is sufficient to skip the FirstRun wizard. The
# value is never persisted to disk and never returned by GET /api/config; it
# is read straight into the SDK adapter at agent-build time. A persisted key
# saved via the GUI wins over the env var for the same provider.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# LITELLM_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# --- Deployment knobs (forker-tunable; all optional) -----------------------
# These shape the kiosk/demo/embedded experience without code changes. They
# are exposed via GET /api/config so the SPA renders accordingly.
#
# Inline HTML banner (sanitized via bleach; allowed tags: a, strong, em, b,
# i, br, span). Useful for "Demo mode" or compliance notices.
# WISDOM_STUDIO_BANNER_HTML=<strong>Demo</strong> sandbox — data resets nightly.
#
# Idle session lifetime in minutes. The SPA shows a countdown and forces
# re-auth on expiry.
# WISDOM_STUDIO_SESSION_TTL_MINUTES=15
#
# Path to a SeedSpec JSON. Applied at startup to pre-populate agents,
# memories, and directives. See examples/seeds/ for templates.
# WISDOM_STUDIO_SEED_PATH=/app/examples/seeds/researcher.json
#
# Force every agent onto a single provider (and optionally a single model).
# Format: "<provider>" (e.g. "anthropic") or "<provider>:<model>". The wizard
# hides provider selection when set; the API also enforces it server-side.
# WISDOM_STUDIO_LOCK_PROVIDER=anthropic
#
# Hide the Settings page entirely (read-only deployment).
# WISDOM_STUDIO_HIDE_SETTINGS=true
#
# Disable agent create/delete in the GUI and API.
# WISDOM_STUDIO_HIDE_AGENT_CRUD=true
#
# Custom docs URL — replaces the default link in the help menu.
# WISDOM_STUDIO_DOCS_URL=https://example.com/docs
#
# License-key signup CTA shown beside the license-key input (FirstRun and
# Settings). Unset by default — the public source ships without a hardcoded
# commercial CTA. Deployments that want the link set this explicitly. Empty
# string is treated the same as unset (suppresses the link entirely).
# WISDOM_STUDIO_SIGNUP_URL=https://example.com/signup
#
# Single-visitor demo posture. Skips FirstRun (env keys must be set), forces
# Settings + agent CRUD hidden, and prevents any writes to studio.json so the
# container is safe to tear down between visitors. Combine with TTL or token
# cap for a bounded try-it-now box.
# WISDOM_STUDIO_EPHEMERAL=true
#
# Hard cap on total LLM tokens (input + output) per session. Counted across
# every SDK-driven call (chat, dreams, critic, directives). When reached, the
# backend returns 410 and the SPA shows the session-ended view.
# WISDOM_STUDIO_TOKEN_CAP_PER_SESSION=50000
#
# Optional CTA shown on the session-ended / cap-reached view. Empty string
# suppresses the CTA entirely (same convention as WISDOM_STUDIO_SIGNUP_URL).
# WISDOM_STUDIO_SESSION_END_CTA_HREF=https://example.com/signup
# WISDOM_STUDIO_SESSION_END_CTA_LABEL=Make your own
